{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build PCM5122 Component (Local) - Media Player",
      "type": "shell",
      "command": "${workspaceFolder}/.venv/bin/esphome",
      "args": [
        "compile",
        "components/pcm5122/yaml/hifi-esp32-plus-media-player.yaml"
      ],
      "env": {
        "PLATFORMIO_CORE_DIR": "${workspaceFolder}/.platformio"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": [],
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      }
    },
    {
      "label": "Build PCM5122 Component (Local) - Sendspin",
      "type": "shell",
      "command": "${workspaceFolder}/.venv/bin/esphome",
      "args": [
        "compile",
        "components/pcm5122/yaml/hifi-esp32-plus-sendspin.yaml"
      ],
      "env": {
        "PLATFORMIO_CORE_DIR": "${workspaceFolder}/.platformio"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": [],
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      }
    },
    {
      "label": "Run PCM5122 Component (Local - esphome run) - Media Player",
      "type": "shell",
      "command": "bash",
      "args": [
        "${workspaceFolder}/.vscode/esphome-run.sh",
        "components/pcm5122/yaml/hifi-esp32-plus-media-player.yaml"
      ],
      "env": {
        "PLATFORMIO_CORE_DIR": "${workspaceFolder}/.platformio"
      },
      "group": "build",
      "problemMatcher": [],
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      }
    },
    {
      "label": "Run PCM5122 Component (Local - esphome run) - Sendspin",
      "type": "shell",
      "command": "bash",
      "args": [
        "${workspaceFolder}/.vscode/esphome-run.sh",
        "components/pcm5122/yaml/hifi-esp32-plus-sendspin.yaml"
      ],
      "env": {
        "PLATFORMIO_CORE_DIR": "${workspaceFolder}/.platformio"
      },
      "group": "build",
      "problemMatcher": [],
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      }
    }
  ]
}
